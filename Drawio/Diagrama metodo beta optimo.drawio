        <mxCell id="grRm8oqtUzIBTe1f2B_--12" value="\begin{aligned} A &amp;amp;= cos(\theta_z)&amp;nbsp;\\ B &amp;amp;= sin(\theta_z)·cos(\gamma_s - \gamma_p) \end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="grRm8oqtUzIBTe1f2B_--34">
