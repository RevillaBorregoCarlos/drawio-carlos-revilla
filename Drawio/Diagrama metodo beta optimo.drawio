        <mxCell id="grRm8oqtUzIBTe1f2B_--1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="140" y="70" width="530" height="500" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--2" value="$$ \text{Cálculo de }\beta_{opt}\text{ analíticamente} $$" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="225" y="80" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--3" value="$$ \text{Mediciones de DNI y DHI} $$" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="160" y="120" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--4" value="$$\text{Ángulos solares y del panel: } \\ \alpha, \gamma_p, \gamma_s, \theta_z$$" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="414" y="115" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--7" value="&lt;div style=&quot;text-align: start; font-family: &amp;quot;Segoe UI&amp;quot;; font-size: 14px; line-height: 20px;&quot;&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;div style=&quot;text-wrap-mode: wrap; line-height: 20px;&quot;&gt;\begin{aligned} \theta &amp;amp;: \mathrm{Ángulo\ de\ incidencia} &amp;amp; \\ \alpha &amp;amp;: \mathrm{Elevacion\ solar} \\ \gamma_p &amp;amp;: \mathrm{Azimut\ del\ panel\ (90^\circ\ manana,\ 270^\circ\ tarde)} \\ \gamma_s &amp;amp;: \mathrm{Azimut\ solar} \\ \theta_z &amp;amp;: \mathrm{Angulo\ de\ cenit} \end{aligned}&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="670" y="80" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--9" value="\begin{aligned} (1)\ G_{POA} &amp;amp;= DNI·cos(\theta) + DHI·\frac{1+cos{\beta}}{2} \\ (2)\ cos(\theta) &amp;amp;= cos(\theta_z)·cos(\beta) + sin(\theta_z)·cos(\gamma_s - \gamma_p)·sin(\beta) \end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1130" y="110" width="390" height="60" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--10" value="" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1167" y="175" as="sourcePoint" />
            <mxPoint x="1167" y="254" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--14" value="\begin{aligned} (3)\ cos(\theta) &amp;amp;= A·cos(\beta) + B·sin(\beta) \end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1128.5" y="240" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--15" value="\begin{equation} Sustituyendo\ (3)\ en\&amp;nbsp; (1)\ y\ reagrupando \end{equation}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1157.25" y="310" width="292.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--16" value="\begin{equation} Ecuaciones\ de \ partida \end{equation}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1206" y="80" width="195" height="30" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--18" value="\begin{aligned} (4)\ G_{POA}(\beta) &amp;amp;=&amp;nbsp; cos(\beta)·(DNI·A + \frac{1}{2}·DHI) + sin(\beta)·(DNI·B) + \frac{1}{2}DHI \end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1120" y="330" width="490" height="60" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--19" value="\begin{equation} Maximización:\ Derivada\ =\ 0 \end{equation}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1175" y="390" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--20" value="\begin{aligned}&amp;nbsp; \frac{\partial G_{POA}(\beta)}{\partial \beta} &amp;amp;=&amp;nbsp; -sin(\beta)·(DNI·A + \frac{1}{2}·DHI) + cos(\beta)·(DNI·B) = 0 \end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1120" y="420" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--21" value="\begin{equation} Dividiendo\ entre\ el\ coseno\ y\ resolviendo \end{equation}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1148" y="485" width="294" height="30" as="geometry" />
        </mxCell>
        <mxCell id="grRm8oqtUzIBTe1f2B_--22" value="\begin{aligned}&amp;nbsp; tan(\beta) &amp;amp;= \frac{DNI·B}{DNI·A + \frac{1}{2}·DHI} \\&amp;nbsp;&amp;nbsp;\beta &amp;amp;= arctan\left(\frac{DNI·B}{DNI·A + \frac{1}{2}·DHI}\right)&amp;nbsp;\end{aligned}" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1120" y="530" width="260" height="90" as="geometry" />
        </mxCell>
